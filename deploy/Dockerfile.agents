# Container for the FractionAX agents service (FastAPI + Anthropic/MiniMax).
#
# Build context MUST be the meta-repo root so the path dependency on the shared
# libs/py-core resolves:
#   docker build -f deploy/Dockerfile.agents -t fractionax-agents .
#
# Runtime config (env): ANTHROPIC_API_KEY and/or MINIMAX_API_KEY, optional
# NAV_ORACLE_PROVIDER / PYTH_HERMES_URL. Hosts inject $PORT.
FROM ghcr.io/astral-sh/uv:python3.13-bookworm-slim

# git to clone the agents service (it lives in its own repo and is a submodule of
# the meta-repo; hosts don't initialize submodules during Docker builds).
RUN apt-get update && apt-get install -y --no-install-recommends git \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Shared domain library — in-repo, present in the build context. The agents
# service depends on it via a relative path (../../libs/py-core), so the layout
# here mirrors the meta-repo.
COPY libs/py-core /app/libs/py-core
# Agents service — cloned directly so the build doesn't depend on submodule init.
ARG AGENTS_REF=main
RUN git clone --depth 1 --branch "$AGENTS_REF" \
  https://github.com/fractionaxapp/agents.git /app/ai/agents

WORKDIR /app/ai/agents
ENV UV_COMPILE_BYTECODE=1 UV_LINK_MODE=copy
RUN uv sync --no-dev --frozen

EXPOSE 8000
CMD ["sh", "-c", "uv run uvicorn fractionax_agents.server:app --host 0.0.0.0 --port ${PORT:-8000}"]
