engine-strict=true
auto-install-peers=true
dedupe-peer-dependents=true
prefer-workspace-packages=true
link-workspace-packages=deep
save-workspace-protocol=rolling
# Wait 7 days before resolving a newly published version (npm 11.10+); mirrors
# the pnpm minimumReleaseAge in pnpm-workspace.yaml for npm-based tooling.
min-release-age=7
